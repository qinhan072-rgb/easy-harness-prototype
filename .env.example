# Easy Harness Stage 2A environment template.
# Copy to local secret stores only. Never commit real keys.

# Frontend public values
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_APP_BASE_URL=http://127.0.0.1:5173

# Supabase Edge Function server values
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
APP_BASE_URL=
EASY_HARNESS_INTEGRATION_MODE=test

# Payment providers
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# DHL Express China / global API account
DHL_API_KEY=
DHL_API_SECRET=
DHL_ACCOUNT_NUMBER=
DHL_SHIPPER_ACCOUNT=

# Notification providers
EMAIL_FROM=support@example.com
EMAIL_PROVIDER_API_KEY=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Stage 3 upload assistant and request-basis organization
# Recommended first provider for this platform stage.
AI_DRAFT_PROVIDER=qwen
QWEN_API_KEY=
QWEN_MODEL=qwen3.6-plus
QWEN_MAX_TOKENS=12000
AI_DRAFT_PLATFORM_WALL_CLOCK_MS=140000
AI_DRAFT_JOB_BUDGET_MS=125000
AI_DRAFT_FIRST_PASS_TIMEOUT_MS=100000
AI_DRAFT_AUDIT_PASS_TIMEOUT_MS=20000
AI_DRAFT_PROVIDER_REQUEST_TIMEOUT_MS=110000
AI_DRAFT_PROVIDER_STATUS_TIMEOUT_MS=15000
# Supabase Edge Function tries to return the upload assistant result quickly.
# If this budget is exceeded, EdgeRuntime.waitUntil keeps the same online
# function run writing back the result without a local worker.
AI_UPLOAD_ASSISTANT_FAST_RESPONSE_MS=45000
# Optional override; defaults to Alibaba Cloud DashScope OpenAI-compatible mode.
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# On by default: run a second semantic pass that audits evidence, request-basis
# closure, and customer questions before saving the result.
AI_DRAFT_ENABLE_EVIDENCE_AUDIT=true
# Off by default: when enabled, run-checking sends selected uploaded image
# attachments to Qwen through short-lived Supabase signed URLs.
AI_DRAFT_ENABLE_ATTACHMENT_VISION=false
AI_DRAFT_MAX_VISION_IMAGES=4
AI_DRAFT_SIGNED_URL_TTL_SECONDS=600
# Optional attachment observations limits. Text/CSV stays small; PDF/XLSX probes
# allow a larger but bounded file size in the Edge Function.
AI_DRAFT_TEXT_ATTACHMENT_MAX_BYTES=200000
AI_DRAFT_STRUCTURED_ATTACHMENT_MAX_BYTES=2000000
# Optional Qwen file-extract bridge for PDF/DOCX/XLSX/CSV/JSON/TXT/MD and
# common image files that are not already sent through vision image_url.
AI_DRAFT_ENABLE_QWEN_FILE_EXTRACT=false
QWEN_FILE_EXTRACT_MODEL=qwen-long
QWEN_FILE_EXTRACT_MAX_TOKENS=5000
AI_DRAFT_QWEN_FILE_EXTRACT_MAX_FILES=4
AI_DRAFT_QWEN_FILE_EXTRACT_MAX_BYTES=10000000
AI_DRAFT_QWEN_FILE_EXTRACT_POLL_ATTEMPTS=8
AI_DRAFT_QWEN_FILE_EXTRACT_POLL_INTERVAL_MS=750
# Lightweight CAD metadata probe for STEP/STP, DXF, OBJ, STL, and limited IGES.
# DWG/3MF/FCStd still need an external converter for visual inspection.
AI_DRAFT_CAD_METADATA_MAX_BYTES=10000000

# Optional fallback provider
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_REASONING_EFFORT=max
DEEPSEEK_MAX_TOKENS=12000
# Optional override; defaults to https://api.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Operational configuration
DEFAULT_ORIGIN_COUNTRY=CN
DEFAULT_ORIGIN_CITY=Shenzhen
DEFAULT_INCOTERM=DAP
DEFAULT_CURRENCY=USD
